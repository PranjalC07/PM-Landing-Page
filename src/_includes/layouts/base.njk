<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">

    <!-- DNS Prefetch & Preconnect for Performance -->
    <link rel="dns-prefetch" href="https://fonts.googleapis.com">
    <link rel="dns-prefetch" href="https://fonts.gstatic.com">
    <link rel="preconnect" href="https://fonts.googleapis.com" crossorigin>
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>

    <!-- Primary Meta Tags -->
    <title>{{ title }} | PM Portfolio</title>
    <meta name="title" content="{{ title }} | PM Portfolio">
    <meta name="description" content="{{ description or 'Product Manager portfolio showcasing expertise in product strategy, user research, and cross-functional leadership.' }}">
    <meta name="keywords" content="Product Manager, PM, B2B SaaS, Product Strategy, User Research, Data Analytics, Agile, Roadmapping, Product Leadership">
    <meta name="author" content="Your Name">
    <meta name="robots" content="index, follow">

    <!-- Canonical URL -->
    <link rel="canonical" href="{{ url or 'https://yourportfolio.com' }}{{ page.url | replace('index.html', '') }}">

    <!-- Open Graph / Social Media -->
    <meta property="og:type" content="website">
    <meta property="og:title" content="{{ title }} | PM Portfolio">
    <meta property="og:description" content="{{ description or 'Product Manager portfolio showcasing expertise in product strategy, user research, and cross-functional leadership.' }}">
    <meta property="og:image" content="{{ image or '/images/og-image.png' }}">
    <meta property="og:image:width" content="1200">
    <meta property="og:image:height" content="630">
    <meta property="og:image:alt" content="{{ title }} - PM Portfolio">
    <meta property="og:url" content="{{ url or 'https://yourportfolio.com' }}{{ page.url | replace('index.html', '') }}">
    <meta property="og:site_name" content="PM Portfolio">

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image">
    <meta name="twitter:title" content="{{ title }} | PM Portfolio">
    <meta name="twitter:description" content="{{ description or 'Product Manager portfolio showcasing expertise in product strategy, user research, and cross-functional leadership.' }}">
    <meta name="twitter:image" content="{{ image or '/images/og-image.png' }}">
    <meta name="twitter:image:alt" content="{{ title }} - PM Portfolio">
    <meta name="twitter:site" content="@yourhandle">
    <meta name="twitter:creator" content="@yourhandle">

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg">
    <link rel="icon" type="image/png" href="/favicon.png">
    <link rel="apple-touch-icon" href="/apple-touch-icon.png">

    <!-- Theme Color for Mobile Browsers -->
    <meta name="theme-color" content="#1a365d" media="(prefers-color-scheme: light)">
    <meta name="theme-color" content="#0f172a" media="(prefers-color-scheme: dark)">

    <!-- Critical CSS (inlined for above-the-fold content) -->
    <style>
      /* Theme Variables */
      :root {
        --color-primary-50: #f0f4f8;
        --color-primary-100: #d9e2ec;
        --color-primary-200: #bcccdc;
        --color-primary-300: #9fb3c8;
        --color-primary-400: #829ab1;
        --color-primary-500: #607d8b;
        --color-primary-600: #486581;
        --color-primary-700: #3e5c81;
        --color-primary-800: #324b6e;
        --color-primary-900: #1a365d;
        --color-primary-950: #0f2949;

        --color-secondary-50: #e6f7f5;
        --color-secondary-100: #ccefeb;
        --color-secondary-200: #99dfd7;
        --color-secondary-300: #66cfc3;
        --color-secondary-400: #33bfaf;
        --color-secondary-500: #00a896;
        --color-secondary-600: #008f82;
        --color-secondary-700: #00746b;
        --color-secondary-800: #005952;
        --color-secondary-900: #003f3a;
        --color-secondary-950: #002823;

        --color-accent-50: #fef0ee;
        --color-accent-100: #fde0dd;
        --color-accent-200: #fbc4be;
        --color-accent-300: #f9a499;
        --color-accent-400: #f7846f;
        --color-accent-500: #f25c54;
        --color-accent-600: #d44a3f;
        --color-accent-700: #b23930;
        --color-accent-800: #912e26;
        --color-accent-900: #742420;
        --color-accent-950: #4a1a14;

        --font-family-sans: 'Inter', system-ui, sans-serif;
        --font-family-serif: 'Playfair Display', Georgia, serif;
        --font-family-mono: 'JetBrains Mono', Consolas, monospace;

        --shadow-soft: 0 2px 15px -3px rgba(0, 0, 0, 0.07), 0 10px 20px -2px rgba(0, 0, 0, 0.04);
        --shadow-glow: 0 0 20px rgba(0, 168, 150, 0.3);
      }

      /* Base Styles */
      html {
        scroll-behavior: smooth;
      }

      body {
        font-family: var(--font-family-sans);
        color: #1a202c;
        -webkit-font-smoothing: antialiased;
        -moz-osx-font-smoothing: grayscale;
      }

      h1, h2, h3, h4, h5, h6 {
        font-family: var(--font-family-serif);
        font-weight: 700;
      }

      /* Custom Utilities */
      .btn {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        padding: 0.75rem 1.5rem;
        font-size: 1rem;
        font-weight: 500;
        border-radius: 0.5rem;
        transition: all 0.3s ease;
        outline: none;
      }

      .btn:focus {
        outline: 2px solid;
        outline-offset: 2px;
      }

      .btn-primary {
        background-color: var(--color-primary-500);
        color: white;
      }

      .btn-primary:hover {
        background-color: var(--color-primary-600);
        box-shadow: var(--shadow-glow);
      }

      .btn-primary:focus {
        ring: 2px;
        ring-color: var(--color-primary-500);
      }

      .btn-secondary {
        background-color: var(--color-secondary-500);
        color: white;
      }

      .btn-secondary:hover {
        background-color: var(--color-secondary-600);
      }

      .btn-secondary:focus {
        ring: 2px;
        ring-color: var(--color-secondary-500);
      }

      /* Animations */
      @keyframes fadeIn {
        0% { opacity: 0; }
        100% { opacity: 1; }
      }

      .animate-fade-in {
        animation: fadeIn 0.6s ease-out forwards;
      }

      /* Container */
      .container {
        width: 100%;
        max-width: 1280px;
        margin-left: auto;
        margin-right: auto;
        padding-left: 1rem;
        padding-right: 1rem;
      }

      @media (min-width: 640px) {
        .container {
          padding-left: 1.5rem;
          padding-right: 1.5rem;
        }
      }

      @media (min-width: 1024px) {
        .container {
          padding-left: 2rem;
          padding-right: 2rem;
        }
      }

      /* Text Balance */
      .text-balance {
        text-wrap: balance;
      }

      /* Hero Section Critical Styles */
      #hero {
        min-height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
        background: linear-gradient(135deg, var(--color-primary-50) 0%, white 50%, var(--color-secondary-50) 100%);
        padding-top: 4rem;
      }

      #hero h1 {
        font-size: 3rem;
        line-height: 1.2;
        margin-bottom: 1.5rem;
      }

      @media (min-width: 768px) {
        #hero h1 {
          font-size: 4.5rem;
        }
      }

      #hero p {
        font-size: 1.25rem;
        line-height: 1.6;
        margin-bottom: 2rem;
        color: #4a5568;
      }

      @media (min-width: 768px) {
        #hero p {
          font-size: 1.5rem;
        }
      }

      #hero .btn {
        width: 100%;
        margin-bottom: 0.5rem;
      }

      @media (min-width: 640px) {
        #hero .btn {
          width: auto;
        }
      }
    </style>

    <!-- Preload Critical Resources -->
    <link rel="preload" href="/css/output.css" as="style">
    <link rel="preload" href="/js/main.js" as="script">

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Playfair+Display:wght@400;500;600;700&display=swap" rel="stylesheet">

    <!-- Styles -->
    <link rel="stylesheet" href="/css/output.css">

    <!-- Enhanced JSON-LD Structured Data -->
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "Person",
      "name": "Your Name",
      "jobTitle": "Senior Product Manager",
      "url": "https://yourportfolio.com",
      "sameAs": [
        "https://linkedin.com/in/yourprofile",
        "https://github.com/yourusername",
        "https://twitter.com/yourhandle"
      ],
      "knowsAbout": [
        "Product Management",
        "B2B SaaS",
        "Product Strategy",
        "User Research",
        "Data Analytics",
        "Agile",
        "Roadmapping"
      ],
      "worksFor": {
        "@type": "Organization",
        "name": "Your Company"
      }
    }
    </script>
  </head>
  <body class="bg-white text-gray-900">
    {% include "header.njk" %}
    <main>
      {{ content | safe }}
    </main>
    {% include "footer.njk" %}
    <script src="/js/main.js" defer></script>
  </body>
</html>